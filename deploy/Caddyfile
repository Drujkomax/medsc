# ============================================================================
# Caddy reverse proxy for self-hosted Supabase (RUN ON THE SERVER)
# ----------------------------------------------------------------------------
# Terminates HTTPS (auto Let's Encrypt) and forwards to Kong on :8000.
# Point a DNS A record (e.g. api.medsc.uz) to this server's IP first.
#
# Install:  apt-get install -y caddy   (or see https://caddyserver.com/docs/install)
# Put this file at /etc/caddy/Caddyfile, then:  systemctl reload caddy
# ============================================================================

# Replace api.medsc.uz with your real subdomain.
api.medsc.uz {
    # All Supabase APIs (auth, rest, storage, functions, realtime) go through Kong.
    reverse_proxy localhost:8000
}

# OPTIONAL: expose Studio on its own subdomain (Studio also has HTTP basic-auth
# via DASHBOARD_USERNAME/PASSWORD). Restrict by IP if possible.
